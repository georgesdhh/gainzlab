{% extends 'base.html.twig' %}

{% block title %}{{ 'product.title'|trans }} — GainzLab{% endblock %}

{% block body %}

{% if lowStock and is_granted('ROLE_ADMIN') %}
<div class="alert alert-warning">
    <strong>{{ 'product.low_stock'|trans }} :</strong>
    {% for p in lowStock %}
        {{ p.name }} ({{ p.stock }}){% if not loop.last %}, {% endif %}
    {% endfor %}
</div>
{% endif %}

<div class="d-flex justify-content-between align-items-center page-title">
    <h1 class="mb-0">{{ 'product.title'|trans }}</h1>
    {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_product_new') }}" class="btn btn-primary btn-sm">{{ 'product.new'|trans }}</a>
    {% endif %}
</div>

<form method="get" class="row g-2 mb-4">
    <div class="col-md-3">
        <input type="text" name="name" class="form-control" placeholder="{{ 'product.search'|trans }}" value="{{ app.request.get('name') }}">
    </div>
    <div class="col-md-3">
        <select name="category" class="form-select">
            <option value="">{{ 'product.all_categories'|trans }}</option>
            {% for cat in ['Protéines','Créatine','Acides Aminés','Vitamines','Brûleurs','Barres & Snacks','Hydratation'] %}
                <option value="{{ cat }}" {{ app.request.get('category') == cat ? 'selected' : '' }}>{{ cat }}</option>
            {% endfor %}
        </select>
    </div>
    <div class="col-md-2">
        <input type="number" name="max_price" class="form-control" placeholder="{{ 'product.max_price'|trans }}" value="{{ app.request.get('max_price') }}">
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">{{ 'product.filter'|trans }}</button>
    </div>
    <div class="col-md-2">
        <a href="{{ path('app_product_index') }}" class="btn btn-outline-secondary w-100">{{ 'product.reset'|trans }}</a>
    </div>
</form>

<div class="row g-3">
    {% for product in products %}
    <div class="col-md-4 col-lg-3">
        <div class="card h-100 border" style="border-radius: 8px; overflow: hidden;">
            <div class="card-body d-flex flex-column">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <span class="badge bg-secondary" style="font-size: 0.7rem; font-weight: 600; text-transform: uppercase;">{{ product.category }}</span>
                    {% if product.promoTag %}
                        <span class="badge" style="background-color: var(--gl-accent); font-size: 0.7rem;">{{ product.promoTag }}</span>
                    {% endif %}
                </div>
                <h6 class="card-title fw-bold mb-1" style="font-family: 'Barlow Condensed', sans-serif; font-size: 1.1rem; text-transform: uppercase;">{{ product.name }}</h6>
                <div class="mb-1">
                    {% set avg = product.averageRating %}
                    {% if avg %}
                        <span style="color: var(--gl-accent); font-size: 0.95rem;">
                            {% for i in 1..5 %}{{ i <= avg ? '★' : '☆' }}{% endfor %}
                        </span>
                        <span class="text-muted" style="font-size: 0.75rem;">{{ avg }}/5</span>
                    {% else %}
                        <span class="text-muted" style="font-size: 0.75rem;">{{ 'product.not_rated'|trans }}</span>
                    {% endif %}
                </div>
                <p class="text-muted small mb-3">{{ product.country ?? '—' }}</p>
                <div class="mt-auto">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <span class="fw-bold fs-5" style="color: var(--gl-accent)">{{ product.price }} €</span>
                            {% if product.originalPrice %}
                                <span class="text-muted small text-decoration-line-through ms-1">{{ product.originalPrice }} €</span>
                            {% endif %}
                        </div>
                        <span class="badge {{ product.stock < product.stockThreshold ? 'bg-danger' : 'bg-success' }}" style="font-size: 0.7rem;">
                            {{ 'product.stock'|trans }} : {{ product.stock }}
                        </span>
                    </div>
                    <div class="d-flex gap-1">
                        <a href="{{ path('app_product_show', {id: product.id}) }}" class="btn btn-sm btn-outline-secondary flex-grow-1">{{ 'product.show'|trans }}</a>
                        <form method="post" action="{{ path('app_cart_quick_add', {id: product.id}) }}">
                            <button class="btn btn-sm btn-primary">{{ 'product.add_to_cart'|trans }}</button>
                        </form>
                    </div>
                    {% if is_granted('ROLE_ADMIN') %}
                    <div class="d-flex gap-1 mt-1">
                        <a href="{{ path('app_product_edit', {id: product.id}) }}" class="btn btn-sm btn-outline-warning flex-grow-1">{{ 'product.edit'|trans }}</a>
                        <form method="post" action="{{ path('app_product_duplicate', {id: product.id}) }}">
                            <button class="btn btn-sm btn-outline-secondary" title="{{ 'product.duplicate'|trans }}">⧉</button>
                        </form>
                        <form method="post" action="{{ path('app_product_delete', {id: product.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                            <button class="btn btn-sm btn-outline-danger" onclick="return confirm('{{ 'product.delete'|trans }} ?')">✕</button>
                        </form>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
    {% else %}
    <div class="col-12 text-center py-5 text-muted">
        {{ 'product.no_result'|trans }}
    </div>
    {% endfor %}
</div>

{% endblock %}
