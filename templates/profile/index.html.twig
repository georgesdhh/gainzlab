{% extends 'base.html.twig' %}

{% block title %}{{ 'profile.title'|trans }} — GainzLab{% endblock %}

{% block body %}

<div class="page-title mb-4">
    <h1 class="mb-0">{{ 'profile.title'|trans }}</h1>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card border h-100" style="border-radius: 8px;">
            <div class="card-body p-4">
                <div class="mb-3 pb-3 border-bottom">
                    <p class="text-muted small text-uppercase mb-1">{{ 'profile.full_name'|trans }}</p>
                    <p class="fw-bold mb-0">{{ user.fullName }}</p>
                </div>
                <div class="mb-3 pb-3 border-bottom">
                    <p class="text-muted small text-uppercase mb-1">{{ 'auth.email'|trans }}</p>
                    <p class="fw-bold mb-0">{{ user.email }}</p>
                </div>
                <div>
                    <p class="text-muted small text-uppercase mb-1">{{ 'profile.role'|trans }}</p>
                    {% if is_granted('ROLE_ADMIN') %}
                        <p class="fw-bold mb-0">{{ 'profile.role_admin'|trans }}</p>
                    {% else %}
                        <p class="fw-bold mb-0">{{ 'profile.role_user'|trans }}</p>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <h2 class="mb-3" style="font-size: 1.4rem;">{{ 'profile.my_carts'|trans }}</h2>
        {% if user.carts is empty %}
            <p class="text-muted">{{ 'profile.no_carts'|trans }}</p>
        {% else %}
            <div class="row g-3">
                {% for cart in user.carts %}
                <div class="col-md-6">
                    <div class="card border" style="border-radius: 8px;">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="fw-bold small text-uppercase text-muted">{{ 'profile.cart_number'|trans }} #{{ loop.index }}</span>
                                <span class="badge bg-secondary">{{ cart.cartItems|length }} {{ 'cart.items'|trans }}</span>
                            </div>
                            <p class="small text-muted mb-3">
                                {{ cart.createdAt ? cart.createdAt|date('d/m/Y à H:i') : '—' }}
                            </p>
                            <a href="{{ path('app_cart_show', {id: cart.id}) }}" class="btn btn-sm btn-outline-secondary w-100">{{ 'product.show'|trans }}</a>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</div>

{% endblock %}
