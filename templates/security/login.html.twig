{% extends 'base.html.twig' %}

{% block title %}{{ 'auth.login_title'|trans }} — GainzLab{% endblock %}

{% block body %}
<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <h1 class="page-title mb-4">{{ 'auth.login_title'|trans }}</h1>

        {% if error %}
            <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <form method="post">
            <div class="mb-3">
                <label class="form-label fw-600 small text-uppercase">{{ 'auth.email'|trans }}</label>
                <input type="email" name="_username" class="form-control"
                       value="{{ last_username }}" autocomplete="email" required autofocus>
            </div>
            <div class="mb-4">
                <label class="form-label small text-uppercase">{{ 'auth.password'|trans }}</label>
                <input type="password" name="_password" class="form-control"
                       autocomplete="current-password" required>
            </div>
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
            <button type="submit" class="btn btn-primary w-100">{{ 'auth.submit_login'|trans }}</button>
        </form>

        <p class="mt-3 text-center small text-muted">
            {{ 'auth.no_account'|trans }} <a href="{{ path('app_register') }}" style="color: var(--gl-accent)">{{ 'nav.register'|trans }}</a>
        </p>
    </div>
</div>
{% endblock %}
