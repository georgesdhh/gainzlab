{% extends 'base.html.twig' %}

{% block title %}{{ 'cart.add_product'|trans }} — {{ 'cart.show_title'|trans }} #{{ cart.id }}{% endblock %}

{% block body %}

<div class="d-flex justify-content-between align-items-center page-title">
    <h1 class="mb-0">{{ 'cart.add_product'|trans }}</h1>
    <a href="{{ path('app_cart_show', {id: cart.id}) }}" class="btn btn-outline-secondary">{{ 'cart.back'|trans }}</a>
</div>

<div class="row g-4">

    {# Colonne gauche — formulaire sticky #}
    <div class="col-md-4">
        <div class="card border" style="border-radius: 8px; position: sticky; top: 80px;">
            <div class="card-body p-4">
                <p class="small text-uppercase text-muted fw-bold mb-3">{{ 'cart.selection'|trans }}</p>
                <form method="post">
                    <div class="mb-3">
                        <label class="form-label small text-muted">{{ 'product.title'|trans }}</label>
                        <select name="product_id" id="product_select" class="form-select" required>
                            <option value="">{{ 'cart.choose'|trans }}</option>
                            {% for product in products %}
                                <option value="{{ product.id }}" {{ product.stock == 0 ? 'disabled' : '' }}>
                                    {{ product.name }}
                                    {% if product.stock == 0 %}({{ 'cart.out_of_stock'|trans }}){% endif %}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="mb-4">
                        <label class="form-label small text-muted">{{ 'cart.quantity'|trans }}</label>
                        <input type="number" name="quantity" class="form-control" value="1" min="1" required>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">{{ 'cart.add_to_cart_btn'|trans }}</button>
                </form>
            </div>
        </div>
    </div>

    {# Colonne droite — liste des produits disponibles scrollable #}
    <div class="col-md-8">
        <p class="small text-uppercase text-muted fw-bold mb-3">{{ 'cart.available_products'|trans }}</p>
        <div class="d-flex flex-column gap-2" style="max-height: 65vh; overflow-y: auto; padding-right: 4px;">
            {% for product in products %}
            <div class="d-flex justify-content-between align-items-center px-4 py-3 border rounded
                {{ product.stock == 0 ? 'opacity-50' : 'product-row' }}"
                style="border-radius: 8px !important; cursor: {{ product.stock > 0 ? 'pointer' : 'default' }};"
                onclick="{{ product.stock > 0 ? 'document.getElementById(\'product_select\').value=' ~ product.id : '' }}">
                <div>
                    <p class="fw-bold mb-0" style="font-family: 'Barlow Condensed', sans-serif; font-size: 1.05rem; text-transform: uppercase;">{{ product.name }}</p>
                    <p class="text-muted mb-0" style="font-size: 0.82rem;">{{ product.category }}</p>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <span class="fw-bold" style="color: var(--gl-accent); font-size: 1rem;">{{ product.price }} €</span>
                    <span class="badge {{ product.stock == 0 ? 'bg-danger' : (product.stock < product.stockThreshold ? 'bg-warning text-dark' : 'bg-success') }}">
                        {{ product.stock == 0 ? 'cart.out_of_stock'|trans : product.stock ~ ' ' ~ ('cart.in_stock'|trans) }}
                    </span>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>

</div>

<style>
    .product-row:hover {
        border-color: var(--gl-accent) !important;
        background-color: rgba(216, 157, 106, 0.05);
    }
</style>

{% endblock %}
